###############################################################################
# ORN-AI Talent Infrastructure Platform — environment variables
#
# Copy this file to .env (or set these in your hosting provider's UI) before
# starting the app. Variables marked REQUIRED must be set or the server will
# refuse to start.
###############################################################################

# REQUIRED. PostgreSQL connection string.
# - On Replit: provided automatically by the built-in database.
# - On Render: paste the "Internal Database URL" from your Postgres add-on.
#   Render's Postgres requires SSL; the app auto-enables SSL when NODE_ENV=production.
DATABASE_URL=postgres://user:password@host:5432/dbname

# REQUIRED. The TCP port the API server should listen on.
# - On Replit: set automatically by the workflow.
# - On Render: Render injects PORT automatically; do not override.
PORT=8080

# Web app only — base path the SPA is served under (Vite `base`).
# Use "/" when the SPA is hosted at the domain root, or e.g. "/app" when nested.
BASE_PATH=/

# Recommended in production. Switches the API to production logging,
# enables Postgres SSL, and locks down CORS.
NODE_ENV=production

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

###############################################################################
# Render single-service deploy (API serves the built SPA)
###############################################################################

# Set this to the path of the Vite build output, relative to the process CWD
# (the repo root when using the Render build command from the README).
# When set, Express serves the static SPA files and falls back to index.html
# for client-side routes — so a single Render web service hosts both the API
# and the React app, no CORS needed.
#
# Leave UNSET on Replit (the path-based proxy already routes traffic).
WEB_DIST_PATH=artifacts/orn-ai/dist/public

###############################################################################
# Render two-service deploy (separate static site + web service)
###############################################################################

# If you choose to deploy the web app as a separate Render Static Site, set
# WEB_ORIGIN on the API service to that site's full URL (e.g.
# https://orn-ai.onrender.com). The API will then accept cross-origin requests
# only from that origin. Leave unset if WEB_DIST_PATH is used.
# WEB_ORIGIN=https://your-spa.onrender.com
